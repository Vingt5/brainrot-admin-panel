{
  "name": "brainrot-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Bot Discord de collection de brainrots, construit avec Node.js, TypeScript, discord.js et SQLite.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "admin-api:dev": "tsx watch src-admin/index.ts",
    "admin-api:build": "tsc -p tsconfig.admin.json",
    "admin-api:start": "node dist-admin/src-admin/index.js",
    "test": "tsx src/scripts/runTests.ts",
    "start": "node dist/index.js",
    "deploy:commands": "tsx src/scripts/deployCommands.ts",
    "catalog:generate": "tsx src/scripts/generateTopBrainrotCatalog.ts",
    "assets:sync": "tsx src/scripts/syncBrainrotAssets.ts",
    "db:init": "tsx src/scripts/initDb.ts",
    "db:seed": "tsx src/scripts/seedBrainrots.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "cors": "^2.8.5",
    "discord.js": "^14.22.1",
    "dotenv": "^16.5.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
